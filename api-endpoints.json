{
  "v": 1,
  "name": "Socipedia API",
  "folders": [
    {
      "name": "Auth",
      "requests": [
        {
          "name": "Register",
          "method": "POST",
          "url": "http://localhost:8000/api/register/",
          "body": {
            "contentType": "application/json",
            "body": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpassword\",\n  \"email\": \"test@example.com\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\"\n}"
          }
        },
        {
          "name": "Login",
          "method": "POST",
          "url": "http://localhost:8000/api/login/",
          "body": {
            "contentType": "application/json",
            "body": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpassword\"\n}"
          }
        }
      ]
    },
    {
      "name": "Users",
      "requests": [
        {
          "name": "Get Users",
          "method": "GET",
          "url": "http://localhost:8000/api/users/"
        },
        {
          "name": "Get User",
          "method": "GET",
          "url": "http://localhost:8000/api/users/1/"
        },
        {
          "name": "Add Friend",
          "method": "POST",
          "url": "http://localhost:8000/api/users/1/add_friend/",
          "body": {
            "contentType": "application/json",
            "body": "{\n  \"friend_id\": 2\n}"
          }
        },
        {
          "name": "Remove Friend",
          "method": "POST",
          "url": "http://localhost:8000/api/users/1/remove_friend/",
          "body": {
            "contentType": "application/json",
            "body": "{\n  \"friend_id\": 2\n}"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "requests": [
        {
          "name": "Get Posts",
          "method": "GET",
          "url": "http://localhost:8000/api/posts/"
        },
        {
          "name": "Create Post",
          "method": "POST",
          "url": "http://localhost:8000/api/posts/",
          "body": {
            "contentType": "application/json",
            "body": "{\n  \"description\": \"This is a test post\"\n}"
          }
        },
        {
          "name": "Get Post",
          "method": "GET",
          "url": "http://localhost:8000/api/posts/1/"
        }
      ]
    },
    {
      "name": "Comments",
      "requests": [
        {
          "name": "Get Comments",
          "method": "GET",
          "url": "http://localhost:8000/api/comments/"
        },
        {
          "name": "Create Comment",
          "method": "POST",
          "url": "http://localhost:8000/api/comments/",
          "body": {
            "contentType": "application/json",
            "body": "{\n  \"post_id\": 1,\n  \"comment\": \"This is a test comment\"\n}"
          }
        },
        {
          "name": "Get Comment",
          "method": "GET",
          "url": "http://localhost:8000/api/comments/1/"
        }
      ]
    }
